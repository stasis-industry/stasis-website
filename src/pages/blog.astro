---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.status !== 'draft'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Stasis | Research Notes" description="Preliminary observations and methods from ongoing MAFIS experiments. Not peer-reviewed.">
  <Header />

  <main class="blog-page">

    <!-- Masthead -->
    <div class="masthead">
      <div class="masthead-inner">
        <span class="page-label">RESEARCH NOTES</span>
        <p class="page-disclaimer">
          These notes document observations from ongoing experiments.
          They are not peer-reviewed and do not constitute published findings.
          Methods, data, and limitations are stated explicitly in each article.
        </p>
      </div>
    </div>

    <!-- Article list -->
    <div class="posts-section">
      <div class="posts-inner">
        {posts.length === 0 ? (
          <p class="empty-state">No notes published yet.</p>
        ) : (
          posts.map(post => {
            const date = new Date(post.data.date).toLocaleDateString('en-US', {
              year: 'numeric', month: 'long', day: 'numeric',
            });
            return (
              <a href={`/blog/${post.id}`} class="post-card">
                {post.data.image && (
                  <div class="post-image-wrap">
                    <img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} class="post-image" loading="lazy" />
                  </div>
                )}
                <div class="post-body">
                  <div class="post-meta">
                    {post.data.status === 'preliminary' && (
                      <span class="post-badge">PRELIMINARY</span>
                    )}
                    <span class="post-date">{date}</span>
                    <span class="post-sep">·</span>
                    <span class="post-read">{post.data.readTime} min read</span>
                  </div>
                  <h2 class="post-title">{post.data.title}</h2>
                  <p class="post-desc">{post.data.description}</p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="post-tags">
                      {post.data.tags.map(tag => (
                        <span class="post-tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
                <div class="post-arrow">→</div>
              </a>
            );
          })
        )}
      </div>
    </div>

    <!-- Footer -->
    <footer class="blog-footer">
      <div class="footer-inner">
        <span class="footer-copy">&copy; 2026 Stasis</span>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/docs">Docs</a>
          <a href="/simulator">Simulator</a>
          <a href="https://github.com/stasis-industries/mafis" target="_blank" rel="noopener noreferrer">Github ↗</a>
        </div>
      </div>
    </footer>

  </main>
</Layout>

<style>
  .blog-page {
    background: var(--bg);
    color: var(--text);
    padding-top: 70px;
    min-height: 100vh;
  }

  /* ─── Masthead ────────────────────────────────────────── */
  .masthead {
    border-bottom: 1px solid var(--border);
    padding: 40px 24px;
  }
  .masthead-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .page-label {
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-sec);
  }
  .page-disclaimer {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 0.85rem;
    color: var(--text-sec);
    line-height: 1.6;
    max-width: 560px;
    border-left: 2px solid var(--border);
    padding-left: 16px;
    margin: 0;
  }

  /* ─── Posts Section ───────────────────────────────────── */
  .posts-section { padding: 0 24px; }
  .posts-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  .empty-state {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-sec);
    padding: 64px 0;
    opacity: 0.5;
  }

  /* ─── Post Card ───────────────────────────────────────── */
  .post-card {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 24px;
    padding: 40px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--text);
    transition: opacity 0.2s;
  }
  .post-card:hover { opacity: 0.75; }

  .post-image-wrap {
    grid-column: 1 / -1;
    border: 1px solid var(--border);
    overflow: hidden;
    max-height: 280px;
  }
  .post-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-body { display: flex; flex-direction: column; gap: 12px; }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-sec);
  }
  .post-badge {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 2px 8px;
    letter-spacing: 0.12em;
    font-size: 9px;
  }
  .post-sep { opacity: 0.3; }

  .post-title {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.3px;
    color: var(--text);
  }

  .post-desc {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-sec);
    max-width: 560px;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }
  .post-tag {
    font-family: var(--mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-sec);
    opacity: 0.5;
  }
  .post-tag + .post-tag::before { content: '·'; margin-right: 6px; }

  .post-arrow {
    font-family: var(--mono);
    font-size: 18px;
    color: var(--text-sec);
    opacity: 0.3;
    padding-top: 4px;
    align-self: center;
    transition: transform 0.2s, opacity 0.2s;
  }
  .post-card:hover .post-arrow { transform: translateX(4px); opacity: 0.7; }

  /* ─── Footer ──────────────────────────────────────────── */
  .blog-footer { border-top: 1px solid var(--border); padding: 32px 24px; }
  .footer-inner {
    max-width: 720px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
  }
  .footer-copy {
    font-family: var(--mono); font-size: 11px;
    color: var(--text-sec); letter-spacing: 0.04em;
  }
  .footer-links { display: flex; gap: 20px; }
  .footer-links a {
    font-family: var(--mono); font-size: 11px;
    color: var(--text-sec); text-decoration: none;
    text-transform: uppercase; letter-spacing: 0.06em;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--text); }

  /* ─── Responsive ──────────────────────────────────────── */
  @media (min-width: 768px) {
    .masthead { padding: 48px 32px; }
    .masthead-inner { flex-direction: row; align-items: baseline; gap: 48px; }
    .posts-section { padding: 0 32px; }
    .blog-footer { padding: 32px 32px; }
  }
  @media (max-width: 600px) {
    .post-card { grid-template-columns: 1fr; }
    .post-arrow { display: none; }
    .footer-inner { flex-direction: column; gap: 16px; text-align: center; }
  }
</style>
