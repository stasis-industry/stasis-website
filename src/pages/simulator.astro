---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="MAFIS | Fault Resilience Observatory"
  description="Run lifelong multi-agent pathfinding simulations in 3D, inject faults, and measure how warehouse robotics systems degrade and recover. Built in Rust, running in your browser."
>

  <!-- Unavailable state (shown until JS confirms /sim/index.html exists) -->
  <div id="sim-unavailable">
    <div class="sim-content">

      <div class="status-badge">
        <span class="status-dot"></span>
        STATUS: AWAITING RELEASE // V0.1.0
      </div>

      <h1 class="sim-title">
        The observatory is <em>ready.</em>
      </h1>

      <p class="sim-desc">
        29K lines of Rust compiled to WebAssembly. 5 lifelong MAPF solvers, 4 fault scenarios, 60fps. Deploys on the first tagged release.
      </p>

      <div class="sim-links">
        <a href="https://github.com/stasis-industry/mafis/releases" class="btn-sim" target="_blank" rel="noopener">Watch Releases</a>
        <a href="/docs/researchers/introduction" class="btn-sim btn-sim-ghost">Read the Docs</a>
      </div>

      <div class="sim-specs">
        <div class="spec-item"><span class="spec-val">5</span><span class="spec-label">Solvers</span></div>
        <div class="spec-divider"></div>
        <div class="spec-item"><span class="spec-val">4</span><span class="spec-label">Fault scenarios</span></div>
        <div class="spec-divider"></div>
        <div class="spec-item"><span class="spec-val">500</span><span class="spec-label">Max agents</span></div>
        <div class="spec-divider"></div>
        <div class="spec-item"><span class="spec-val">2,520</span><span class="spec-label">Experiment runs</span></div>
      </div>

    </div>
  </div>

  <!-- Live simulator (hidden until JS confirms the file exists) -->
  <iframe
    id="sim-frame"
    src="/sim/index.html"
    title="MAFIS Fault Resilience Observatory"
    allow="fullscreen"
  ></iframe>

  <script is:inline>
    // Run on every navigation (is:inline prevents Astro deduplication with ClientRouter)
    (async () => {
      try {
        const res = await fetch('/sim/index.html', { method: 'HEAD' });
        if (res.ok) {
          document.getElementById('sim-unavailable').style.display = 'none';
          document.getElementById('sim-frame').style.display = 'block';
        }
      } catch {
        // keep unavailable state
      }
    })();
  </script>

</Layout>

<style>
  /* ── Full-viewport reset ─────────────────────────── */
  :global(body:has(#sim-frame[style*="display: block"])) {
    overflow: hidden;
  }

  /* ── Live iframe ─────────────────────────────────── */
  #sim-frame {
    display: none;
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    z-index: 10;
  }

  /* ── Unavailable state ───────────────────────────── */
  #sim-unavailable {
    min-height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    color: var(--text);
    padding: 120px 24px 80px;
  }

  .sim-content {
    max-width: 640px;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  /* Status badge */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-sec);
    padding: 8px 18px;
    border: 1px solid var(--border);
  }
  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse-dot 2s infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 0.4; box-shadow: 0 0 0 0 rgba(4,120,87,0.4); }
    50%       { opacity: 1;   box-shadow: 0 0 8px 2px rgba(4,120,87,0.3); }
  }

  /* Title */
  .sim-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -1px;
    color: var(--text);
    margin: 0;
  }
  .sim-title em {
    color: var(--text);
    opacity: 0.35;
    font-style: italic;
  }

  /* Description */
  .sim-desc {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 1rem;
    color: var(--text-sec);
    max-width: 520px;
    line-height: 1.7;
    margin: 0;
  }

  /* Links */
  .sim-links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .btn-sim {
    display: inline-block;
    font-family: var(--mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 12px 28px;
    text-decoration: none;
    transition: opacity 0.2s;
    background: var(--dark);
    color: var(--bg);
  }
  .btn-sim:hover { opacity: 0.8; }
  .btn-sim-ghost {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text);
  }
  .btn-sim-ghost:hover { opacity: 0.7; }

  /* Specs row */
  .sim-specs {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 24px 32px;
    border: 1px solid var(--border);
    flex-wrap: wrap;
    justify-content: center;
  }
  .spec-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .spec-val {
    font-family: var(--mono);
    font-size: 1.25rem;
    color: var(--text);
    letter-spacing: -0.5px;
  }
  .spec-label {
    font-family: var(--mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-sec);
    opacity: 0.6;
  }
  .spec-divider {
    width: 1px;
    height: 32px;
    background: var(--border);
  }
</style>
