---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="MAFIS | Fault Resilience Observatory"
  description="Run lifelong multi-agent pathfinding simulations in 3D, inject faults, and measure how warehouse robotics systems degrade and recover. Built in Rust, running in your browser."
>

  <iframe
    id="sim-frame"
    src="/sim/index.html"
    title="MAFIS Fault Resilience Observatory"
    allow="fullscreen"
  ></iframe>

</Layout>

<style>
  :global(body:has(#sim-frame)) {
    overflow: hidden;
  }

  #sim-frame {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    z-index: 10;
  }
</style>
